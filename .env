# Shared defaults for every environment.
# Override per-mode in .env.development / .env.staging / .env.production,
# or locally (uncommitted) in .env.local. Only VITE_-prefixed vars reach the app.

# Base URL prepended to every API request.
VITE_API_BASE_URL=/api

# HTTP request timeout in milliseconds.
VITE_API_TIMEOUT=30000

# How the app talks to its API:
#   mock   – in-browser MSW mocks, no backend (development only)
#   proxy  – dev server proxies VITE_API_BASE_URL to VITE_API_PROXY (real backend)
#   direct – call VITE_API_BASE_URL directly (staging / production)
VITE_API_MODE=direct
