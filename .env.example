# Copy to .env.local for machine-specific overrides (git-ignored).
# These are all the VITE_-prefixed variables the app reads. See src/config/index.ts.

# Base URL prepended to every API request.
VITE_API_BASE_URL=/api

# HTTP request timeout in milliseconds.
VITE_API_TIMEOUT=30000

# How the app talks to its API: mock | proxy | direct (see .env for meaning).
VITE_API_MODE=mock

# Backend origin to proxy to when VITE_API_MODE=proxy (dev only), e.g. http://localhost:8080
VITE_API_PROXY=
