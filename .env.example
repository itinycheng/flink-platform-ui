# Copy to .env.local for machine-specific overrides (git-ignored).
# These are all the VITE_-prefixed variables the app reads. See src/config/index.ts.

# Base URL prepended to every API request.
VITE_API_BASE_URL=/api

# HTTP request timeout in milliseconds.
VITE_API_TIMEOUT=30000

# Start MSW request mocking (development only). "true" | "false".
# Ignored when VITE_API_PROXY is set — proxying implies live requests.
VITE_ENABLE_MOCK=false

# Dev-only: proxy VITE_API_BASE_URL to this backend origin (e.g. http://localhost:9104).
# Leave empty to use mocks in development.
VITE_API_PROXY=
