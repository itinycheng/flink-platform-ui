# Local development (npm run dev).

# Default: in-browser MSW mocks, so the UI runs with no backend (works out of the box).
VITE_API_MODE=mock

# To develop against a local backend instead, set VITE_API_MODE=proxy and point
# VITE_API_PROXY at its origin (e.g. http://localhost:8080). Prefer doing this in
# .env.local (git-ignored) so it stays a per-machine choice and doesn't break
# teammates who have no backend running.
VITE_API_PROXY=
