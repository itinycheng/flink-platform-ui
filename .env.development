# Local development (npm run dev).

# Use the in-browser MSW mocks so the UI runs without a backend.
VITE_ENABLE_MOCK=true

# To develop against a real backend instead of mocks, set this to its origin
# (e.g. http://localhost:9104). Vite then proxies VITE_API_BASE_URL to it and
# mocking is automatically disabled. Leave empty to keep using mocks.
VITE_API_PROXY=
